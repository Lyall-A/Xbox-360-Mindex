{
    "defaultTrack": null,
    "defaultAlbum": "Unknown Album",
    "defaultArtist": "Unknown Artist",
    "defaultGenre": "Unknown Genre",

    "artistSeperators": [";"],
    "genreSeperators": [";"],
    "artistJoin": ", ",
    "genreJoin": ", ",
    "useSingleArtist": true,
    "useSingleGenre": true,
    
    "keepTracks": true,
    "checkOriginalFiles": false,
    "backupExistingMindex": true,

    "tracksPath": "tracks",
    "wmaOutputPath": "wma_tracks",
    "manifestOutputPath": "manifest.json",
    "mindexOutputPath": "mindex",

    "extensions": [
        ".wma",
        ".mp3",
        ".wav",
        ".flac",
        ".ogg",
        ".aac",
        ".opus"
    ],
    "ffmpegPath": "./ffmpeg"
}